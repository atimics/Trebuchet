{
  "name": "trebuchet-desktop",
  "version": "1.0.0",
  "description": "Trebuchet token launcher, packaged as a desktop app.",
  "main": "main.js",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "license": "MIT",
  "author": {
    "name": "AnOversizedMooseWithSocks",
    "email": "84553632+AnOversizedMooseWithSocks@users.noreply.github.com"
  },

  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },

  "scripts": {
    "start": "electron .",
    "web": "node server.js",
    "web:dev": "node --watch server.js",
    "check:syntax": "node scripts/check-syntax.mjs",
    "test": "node --test test/*.test.mjs",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },

  "dependencies": {
    "@metaplex-foundation/mpl-token-metadata": "^3.2.1",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "@metaplex-foundation/umi-uploader-irys": "^0.9.2",
    "@metaplex-foundation/umi-web3js-adapters": "^0.9.2",
    "@raydium-io/raydium-sdk-v2": "0.1.144-alpha",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "arconnect": "0.4.2",
    "arweave": "^1.15.7",
    "bn.js": "^5.2.3",
    "bs58": "^6.0.0",
    "bip39": "^3.1.0",
    "decimal.js": "^10.4.3",
    "ed25519-hd-key": "^1.3.0",
    "express": "^4.22.2",
    "marked": "^14.1.4",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4"
  },

  "devDependencies": {
    "@types/node": "^20.14.10",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },

  "overrides": {
    "axios": "^1.16.1",
    "bn.js": "^5.2.3",
    "form-data": "^4.0.5",
    "tar": "^7.5.15",
    "uuid": "^11.1.1",
    "ws": "^8.21.0"
  },

  "build": {
    "appId": "com.makesometokens.trebuchet",
    "productName": "Trebuchet",

    "directories": {
      "buildResources": "build",
      "output": "dist"
    },

    "files": [
      "main.js",
      "server.js",
      "tokenService.js",
      "tokenInfoService.js",
      "lpService.js",
      "swapService.js",
      "walletHelpers.js",
      "rpcConfig.js",
      "secretStore.js",
      "pendingWallets.js",
      "validators.js",
      "metadata.json",
      "README.md",
      "public/**/*",
      "package.json"
    ],

    "asarUnpack": [
      "public/**/*",
      "public/intro.mp4"
    ],

    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": ["dmg"]
    },

    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis"]
    },

    "nsis": {
      "preCompressedFileExtensions": []
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    }
  }
}
