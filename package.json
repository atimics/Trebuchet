{
  "name": "trebuchet-desktop",
  "version": "1.0.0",
  "description": "Trebuchet token launcher, packaged as a desktop app.",
  "main": "main.js",
  "type": "module",
  "license": "MIT",
  "author": "",

  "scripts": {
    "start": "electron .",
    "web": "node server.js",
    "web:dev": "node --watch server.js",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },

  "dependencies": {
    "@metaplex-foundation/mpl-token-metadata": "^3.2.1",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "@metaplex-foundation/umi-uploader-irys": "^0.9.2",
    "@metaplex-foundation/umi-web3js-adapters": "^0.9.2",
    "@raydium-io/raydium-sdk-v2": "0.1.144-alpha",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.2",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "bip39": "^3.1.0",
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "ed25519-hd-key": "^1.3.0",
    "express": "^4.19.2",
    "marked": "^14.1.3",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4"
  },

  "devDependencies": {
    "@types/node": "^20.14.10",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },

  "build": {
    "appId": "com.example.trebuchet",
    "productName": "Trebuchet",

    "directories": {
      "buildResources": "build",
      "output": "dist"
    },

    "files": [
      "main.js",
      "server.js",
      "tokenService.js",
      "tokenInfoService.js",
      "lpService.js",
      "swapService.js",
      "walletHelpers.js",
      "rpcConfig.js",
      "secretStore.js",
      "pendingWallets.js",
      "metadata.json",
      "README.md",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],

    "asarUnpack": [
      "public/**/*",
      "public/intro.mp4"
    ],

    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },

    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis", "portable"]
    },

    "nsis": {
      "preCompressedFileExtensions": []
    },

    "portable": {
      "artifactName": "${productName} ${version} Portable.${ext}"
    },

    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    }
  }
}
